# ── Required ────────────────────────────────────────────────────────────────

# JWT signing secret — minimum 64 random characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-random-chars-minimum

# Admin seed account — used at startup to create the built-in admin user.
ADMIN_EMAIL=admin@midmind.com
ADMIN_PASSWORD=change-me-on-first-deploy

# AI provider API key.
# OpenAI:  get from https://platform.openai.com/api-keys
# Gemini:  get from https://aistudio.google.com  (free tier available)
# Groq:    get from https://console.groq.com      (free tier available)
OPENAI_API_KEY=your-api-key-here

# ── Optional ─────────────────────────────────────────────────────────────────

# Frontend origin allowed by CORS (default: http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# SQLite database file path (default: server/data/midmind.db)
# In production, point this at a persistent disk/volume.
DB_PATH=./data/midmind.db

# Rate limits
# Auth attempts per 15 minutes per IP (default: 20)
AUTH_RATE_LIMIT=20

# New session creations per hour per IP (default: 100)
SESSION_WRITE_RATE_LIMIT=100

# Real attempts required before the answer can be revealed with "give up" (default: 2)
MIN_REAL_ATTEMPTS_BEFORE_GIVEUP=2

# AI provider base URL — controls which provider is used.
# Leave unset for OpenAI (default).
# Gemini:  AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Groq:    AI_BASE_URL=https://api.groq.com/openai/v1
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Model name — must match what the chosen provider supports.
# OpenAI:  gpt-4o-mini
# Gemini:  gemini-2.0-flash
# Groq:    llama-3.3-70b-versatile
OPENAI_MODEL=gemini-2.0-flash

# bcrypt rounds for password hashing (default: 10)
# Increase on high-security deployments; each +1 doubles hashing time.
BCRYPT_ROUNDS=10

# Server port (default: 5050)
PORT=5050
